# ── Local (.env.local) ─────────────────────────────────────────────
# Primary provider (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Free fallback: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alias: GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# With no keys → category-based local hint templates.

# ── Vercel (Settings → Environment Variables) ─────────────────────
# Add the same variables for Production and Preview, then redeploy.
#   GEMINI_API_KEY          → recommended (free tier)
#   ANTHROPIC_API_KEY       → optional (used first when set)
# Do not commit .env.local; Vercel injects vars at runtime.
