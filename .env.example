# ── Local (.env.local) ─────────────────────────────────────────────
# Proveedor principal (opcional)
ANTHROPIC_API_KEY=sk-ant-...

# Fallback gratuito: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alias: GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Sin ninguna key → pistas con plantillas locales por categoría.

# ── Vercel (Settings → Environment Variables) ─────────────────────
# Añadí las mismas variables para Production y Preview, luego redeploy.
#   GEMINI_API_KEY          → recomendado (tier gratis)
#   ANTHROPIC_API_KEY       → opcional (prioridad si está definida)
# No subas .env.local al repo; Vercel inyecta las vars en runtime.
